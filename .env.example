# OpenAI API (ChatGPT Plus用)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs API
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Google Drive認証ファイルのパス
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Instagram投稿設定（後で使用）
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# コンテンツ設定
CHARACTER_NAME=るーにゃ
CHARACTER_AGE=21
CHARACTER_BIRTHDAY=12月20日
CHARACTER_DESCRIPTION=21歳の大学3年生。上京してキャンパスデビューしたものの、ぼっち気味。Instagramでは背伸びした大人っぽい自分を魅せたい。

# スケジュール設定
DAILY_POST_TIME=10:00  # 毎日の投稿時刻（HH:MM）
WEEKLY_POSTS=5  # 週の投稿回数
